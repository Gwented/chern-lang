@def
    bind-> "./main.chrn"
    var->
        // Technically should be i64 I believe
        name: str [Range(0, 5)]
@end

@def
    // What the language is SUPPOSED to look like:
    var->
        name: str
        age: u8
        account: Account
        state: State

    nest->
        struct Account {
            balance: BigFloat [!Range(0.0, 10.0)] #hex
            creation_date: str
        }

        enum State { Ready InProgress Failed Void }

    complex->
        State.variants = 4

    override->
        // Would be a constant for SOME languages
        with JAVA
            // This would be default
            sized, unsized, i64, u64, u32, i16, u16 = i32
        with UNKNOWN
            i32 = unsized
@end

// May remove nest
    nest->
        .expr {
            Let {
                thing: i32
                thing2: u8
            }
            While {
                hi: i32
                hi2: i32
            }
        }

        /*age: u8
        things: List<S|Thing>*/

                    // Why was it called family 💀

         //valid: S|CCODE [Range(0, 500), IsEmpty, IsWhitespace, floor()] #wall #wextra

        //enum: E|Enum
@end
